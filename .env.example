# Backend
DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:5432/sentinel
JWT_SECRET_KEY=  # required — run: openssl rand -hex 32
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Phase 4 AI provider; leave empty to use the deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Realtime simulation
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=8
